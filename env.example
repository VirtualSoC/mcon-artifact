# Copy to `.env` and edit for your machine:  cp env.example .env

# --- MCon (required) ---------------------------------------------------------
# Root of the vsoc tree (contains bin/qemu-system-x86_64, img/, scalebench/).
export BASE_DIR=/path/to/your/workspace
# vsoc Android image dir (kernel, ramdisk.img, system.img, vendor.img, userdata).
export GUEST_IMG_PATH=$BASE_DIR/img/vsoc

# QEMU monitor + adb bridge ports (match config/default.yaml).
export MONITOR_PORT=55555
export BRIDGE_PORT=5555

# GPU selection for NVIDIA PRIME offload (optional; omit on single-GPU hosts).
# export __NV_PRIME_RENDER_OFFLOAD=1
# export __GLX_VENDOR_LIBRARY_NAME=nvidia

# --- VM sizing: unified RAM / CPU knob ---------------------------------------
# The defaults below are computed from THIS host: 75% of host RAM, and host
# threads minus 4. Pin them to a literal instead if you prefer (e.g. VM_MEM=16G),
# or set a per-system override further down.
# See docs/setup.md > "Tuning VM size (RAM / CPU)" for how to pick values.
export VM_MEM="$(awk '/^MemTotal:/ {printf "%dG", int($2*0.75/1048576)}' /proc/meminfo)"
export VM_CPUS="$(( $(nproc) - 4 ))"
[ "$VM_CPUS" -ge 1 ] || export VM_CPUS=1

#
# Per-system overrides (win over VM_MEM / VM_CPUS when set):
#   MCon    : MCON_VM_MEM, MCON_VM_CPUS
#   Redroid : REDROID_VM_MEM, REDROID_VM_CPUS
#   Anbox   : set on the `multipass launch` command (see docs/setup.md)

# --- Baselines (only needed if you enable them) -----------------
# Redroid runs in a Linux VM reached over SSH.
# export REDROID_SSH_HOST=localhost
# export REDROID_SSH_PORT=2222
# export REDROID_SSH_USER=redroid
# export REDROID_SSH_PASS=redroid
